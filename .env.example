ENV=development
APP_NAME=agent-app

# LLM
LLM_API_KEY=api-key
LLM_MODEL=model-name
LLM_CTX_WIN=1000000
LLM_CTX_WIN_THRESHOLD=0.7
LLM_CTX_WIN_SUM_KEEP=0.5

# Postgres
PG_HOST=localhost
PG_PORT=5432
PG_DB=postgres
PG_USER=user
PG_PSW=psw
PG_CONN_MAX=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PSW=

ALLOW_ORIGINS=["my-origin"]

# JWT
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30
JWT_RENEW_DAYS=1